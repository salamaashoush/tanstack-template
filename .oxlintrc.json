{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "react",
    "jsx-a11y",
    "import",
    "unicorn",
    "oxc",
    "vitest"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "settings": {
    "react": {
      "version": "19.0"
    }
  },
  "jsPlugins": [
    { "name": "router", "specifier": "oxlint-plugin-router" },
    { "name": "query", "specifier": "oxlint-plugin-query" }
  ],
  "rules": {
    "no-unused-vars": [
      "error",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ],
    "no-restricted-properties": [
      "error",
      {
        "object": "process",
        "property": "env",
        "message": "Use `import { env } from '~/env'` instead to ensure validated types."
      }
    ],

    "typescript/consistent-type-imports": [
      "warn",
      { "prefer": "type-imports", "fixStyle": "separate-type-imports" }
    ],
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-floating-promises": "error",
    // Not part of the ESLint config this replaced. Enabling it is an opt-in
    // decision: it fires on idiomatic `as` in the vendored shadcn components.
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/no-misused-promises": [
      "error",
      { "checksVoidReturn": { "attributes": false } }
    ],
    "typescript/no-unnecessary-condition": [
      "error",
      { "allowConstantLoopConditions": true }
    ],

    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "error",
    "react/jsx-key": "error",
    // React 19 automatic JSX runtime: React need not be in scope.
    "react/react-in-jsx-scope": "off",

    "import/consistent-type-specifier-style": ["error", "prefer-top-level"],
    "import/first": "error",
    "import/newline-after-import": "error",
    "import/no-duplicates": "error",
    // Side-effect imports (e.g. "vitest-dom/extend-expect") are intentional.
    "import/no-unassigned-import": "off",

    "router/create-route-property-order": "error"
  },
  "options": {
    "typeAware": true,
    "reportUnusedDisableDirectives": "error"
  },
  "overrides": [
    {
      "files": [
        "src/env.ts",
        "playwright.config.ts",
        "scripts/**",
        ".husky/**"
      ],
      "rules": {
        "no-restricted-properties": "off"
      }
    },
    {
      "files": ["**/*.spec.ts", "**/*.spec.tsx", "e2e/**"],
      "rules": {
        "vitest/require-mock-type-parameters": "off"
      }
    },
    {
      // Server-only, no React here. TanStack's session API is named
      // `useSession` but is not a React hook, so the hooks rule cannot be
      // satisfied by any naming these files could adopt.
      "files": ["src/utils/session.ts", "src/server/**"],
      "rules": {
        "react-hooks/rules-of-hooks": "off"
      }
    },
    {
      // Vendored shadcn registry code: regenerated by `shadcn add`, so local
      // edits to satisfy these are lost on the next re-sync. Correctness rules
      // still apply; only house-style and registry-design rules are relaxed.
      "files": ["src/components/ui/**"],
      "rules": {
        "import/consistent-type-specifier-style": "off",
        "jsx-a11y/label-has-associated-control": "off",
        "jsx-a11y/prefer-tag-over-role": "off",
        "react/no-array-index-key": "off",
        "typescript/no-unnecessary-condition": "off"
      }
    }
  ],
  "ignorePatterns": [
    "src/i18n/**",
    "src/routeTree.gen.ts",
    ".output/**",
    ".nitro/**",
    "dist/**",
    "coverage/**",
    "playwright-report/**"
  ]
}
