{
  "name": "tanstack-template",
  "version": "0.0.0",
  "description": "TanStack Template",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=.env run vite dev",
    "build": "bun --env-file=.env run vite build",
    "start": "node --env-file=.env .output/server/index.mjs",
    "preview": "bun --env-file=.env run vite preview",
    "lint": "oxlint --type-aware && bun scripts/check-i18n.ts",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt --check .",
    "format:write": "oxfmt .",
    "type-check": "tsc --noEmit",
    "test": "bun --env-file=.env run vitest",
    "coverage": "bun --env-file=.env run vitest run --coverage",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:ui": "playwright test --ui --config=playwright.config.ts",
    "test:e2e:install": "playwright install --with-deps",
    "postinstall": "bun scripts/compile-i18n.ts",
    "prepare": "bun .husky/install.mjs && bun scripts/setup.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-form": "^1.33.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.27",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "valibot": "^1.4.2",
    "valibot-env": "^1.0.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.21.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nitro": "3.0.260610-beta",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-plugin-query": "^0.1.1",
    "oxlint-plugin-router": "^0.1.1",
    "oxlint-tsgolint": "^0.24.0",
    "playwright": "^1.61.1",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0",
    "vitest-dom": "^0.1.1"
  },
  "lint-staged": {
    "*": "oxfmt",
    "*.{js,jsx,ts,tsx}": "oxlint --fix"
  },
  "packageManager": "bun@1.4.0",
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core",
    "esbuild",
    "msw"
  ]
}
